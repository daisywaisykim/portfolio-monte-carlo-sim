# ============================================
# C++ Build Artifacts
# ============================================
# Ignore the entire build directory (where CMake compiles)
[Bb]uild/
[Oo]ut/

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Compiled Dynamic Libraries
*.so
*.dylib
*.dll

# Compiled Static Libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app

# ============================================
# vcpkg (Package Manager)
# ============================================
# IMPORTANT: Ignore the directory where vcpkg installs your libraries.
# These are rebuilt from vcpkg.json and are platform-specific.
vcpkg_installed/

# If you installed vcpkg as a subdirectory (not recommended for global use), 
# ignore the tool itself:
# vcpkg/

# ============================================
# CMake Generated Files & Directories
# ============================================

CMakeLists.txt.user
CMakeCache.txt
CMakeFiles
CMakeScripts
Testing
Makefile
cmake_install.cmake
install_manifest.txt
compile_commands.json
CTestTestfile.cmake
_deps
CMakeUserPresets.json

# Install/Test scripts generated by CMake
cmake_install.cmake
install_manifest.txt
CTestTestfile.cmake
DartConfiguration.tcl

# CPack files
CPackConfig.cmake
CPackSourceConfig.cmake
_CPack_Packages/

# ============================================
# VS Code / Cursor / IDEs
# ============================================
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Cursor specific
.cursor/

# ============================================
# Language Server (clangd)
# ============================================
# Indexing cache
.cache/

# CMake generates this for clangd; it's usually pointing to the build folder.
compile_commands.json

# ============================================
# OS Specific
# ============================================
.DS_Store
Thumbs.db