{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug (CodeLLDB)",
            "type": "lldb", 
            "request": "launch",
            // Dynamically grabs the target built by the CMake extension
            "program": "${command:cmake.launchTargetPath}",
            "args": [],
            "cwd": "${workspaceFolder}",
            "terminal": "integrated",
            // Ensures it builds before attaching the debugger
            "preLaunchTask": "CMake: build"
        }
    ]
}